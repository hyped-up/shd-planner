# SHD Planner — Division 2 Build Planner Web App
# Usage: docker compose up -d
# Optional: copy .env.example to .env and configure Google Drive / AI settings

services:
  shd-planner:
    build: .
    container_name: shd-planner
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    networks:
      - proxy
    env_file:
      - path: .env
        required: false
    environment:
      - NODE_ENV=production
      - NEXT_PUBLIC_APP_URL=https://shd-planner.hypebeastin.com
      - HOSTNAME=0.0.0.0
    # Resource limits to prevent runaway memory/CPU usage
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.25'
          memory: 128M
    # Health check using the dedicated health endpoint
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:3000/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    # JSON logging driver for structured log output
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.shd-planner.entrypoints=http"
      - "traefik.http.routers.shd-planner.rule=Host(`shd-planner.hypebeastin.com`)"
      - "traefik.http.middlewares.shd-planner-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.shd-planner.middlewares=shd-planner-https-redirect"
      - "traefik.http.routers.shd-planner-secure.entrypoints=https"
      - "traefik.http.routers.shd-planner-secure.rule=Host(`shd-planner.hypebeastin.com`)"
      - "traefik.http.routers.shd-planner-secure.tls=true"
      - "traefik.http.routers.shd-planner-secure.tls.certresolver=cloudflare"
      - "traefik.http.routers.shd-planner-secure.service=shd-planner"
      - "traefik.http.routers.shd-planner-secure.middlewares=default-headers@file"
      - "traefik.http.services.shd-planner.loadbalancer.server.port=3000"
      - "traefik.docker.network=proxy"

networks:
  proxy:
    external: true
