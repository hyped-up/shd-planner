# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Drive OAuth (required for Drive export/import)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional AI integration (disabled by default)
NEXT_PUBLIC_AI_ENABLED=false
AI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Auto-update settings (Docker only)
# DATA_DIR=/app/data
# RAW_DIR=/app/raw
# DATA_UPDATE_INTERVAL=7d  # Options: 1d, 7d, 14d, 30d
